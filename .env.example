# ─── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────
# Obtener desde: https://console.neon.tech → tu proyecto → Connection string
# DATABASE_URL  → Pooled connection (para la app en runtime)
# DIRECT_URL    → Direct connection (para migrations y db push)

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# ─── Resend (emails) ──────────────────────────────────────────────────────────
# Obtener desde: https://resend.com/api-keys
# Dejar vacío para deshabilitar emails
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@tu-dominio.com"

# ─── Seed (opcional) ──────────────────────────────────────────────────────────
# Si no se definen, el seed usa admin@studio.com / Admin123!
# SEED_ADMIN_EMAIL="admin@tu-dominio.com"
# SEED_ADMIN_PASSWORD="TuContraseñaSegura123!"
