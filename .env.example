# ─── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────
# Obtener desde: https://console.neon.tech → tu proyecto → Connection string
# DATABASE_URL  → Pooled connection (para la app en runtime)
# DIRECT_URL    → Direct connection (para migrations y db push)

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# ─── Resend (emails) ──────────────────────────────────────────────────────────
# Obtener desde: https://resend.com/api-keys
# Dejar vacío para deshabilitar emails
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@tu-dominio.com"

# ─── Seed (opcional) ──────────────────────────────────────────────────────────
# Si no se definen, el seed usa admin@studio.com / Admin123!
# SEED_ADMIN_EMAIL="admin@tu-dominio.com"
# SEED_ADMIN_PASSWORD="TuContraseñaSegura123!"

# ─── Base de datos (Entorno de Desarrollo) ────────────────────────────────────
#
# OPCIÓN A — Neon Branch (recomendada)
#   1. Ve a console.neon.tech → tu proyecto → Branches → Create Branch → nombre: "dev"
#   2. Copia las URLs del branch "dev" y reemplaza las de arriba en tu .env local
#
# DATABASE_URL="postgresql://user:password@ep-xxx-dev-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:password@ep-xxx-dev.region.aws.neon.tech/neondb?sslmode=require"
#
# OPCIÓN B — Segundo proyecto Neon
#   Crea un proyecto separado llamado "csbooking-dev" en console.neon.tech
#   El plan gratuito incluye hasta 10 proyectos.
#
# OPCIÓN C — PostgreSQL local con Docker
#   docker run -d --name csbooking-db \
#     -e POSTGRES_DB=csbooking \
#     -e POSTGRES_USER=postgres \
#     -e POSTGRES_PASSWORD=postgres \
#     -p 5432:5432 postgres:16
#
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/csbooking"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/csbooking"
#
# Tras configurar la BD de desarrollo, ejecutar:
#   npx prisma migrate dev   → aplica migraciones
#   node prisma/seed.mjs     → crea usuario admin inicial
